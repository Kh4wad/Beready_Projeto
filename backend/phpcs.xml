<?xml version="1.0"?>
<ruleset name="App">

    <config name="installed_paths" value="../../cakephp/cakephp-codesniffer,../../slevomat/coding-standard"/>

    <rule ref="CakePHP">
        <!-- Ignora FQN em todos os arquivos -->
        <exclude name="CakePHP.Classes.Import.UseFullyQualifiedName"/>
        <!-- Ignora verificação de nome de classe -->
        <exclude name="PSR1.Classes.ClassDeclaration"/>
    </rule>

    <rule ref="SlevomatCodingStandard">
        <!-- Ignora a regra de FQN do Slevomat também -->
        <exclude name="SlevomatCodingStandard.Namespaces.ReferenceUsedNamesOnly"/>
    </rule>

    <file>src/</file>
    <file>tests/</file>

</ruleset>