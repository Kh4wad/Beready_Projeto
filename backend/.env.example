# APP CONFIGURATION
APP_NAME="Beready"
APP_ENV="development"
APP_BASE_URL="http://localhost:5173"
DEBUG=true

APP_ENCODING="UTF-8"
APP_DEFAULT_LOCALE="pt_BR"
APP_DEFAULT_TIMEZONE="America/Sao_Paulo"

# SECURITY
SECURITY_SALT="coloque_uma_string_forte_aqui"
JWT_SECRET="coloque_um_jwt_super_forte_aqui"

# DATABASE
DATABASE_URL="postgres://USER:PASSWORD@HOST:5432/DB?sslmode=require"

# importante pro supabase:
DATABASE_SSL=true

# EMAIL
EMAIL_FROM="noreply@beready.com"
EMAIL_FROM_NAME="BeReady"

# SENTRY
SENTRY_DSN=""

# CLOUDINARY
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
CLOUDINARY_API_URL="https://api.cloudinary.com/v1_1"
CLOUDINARY_UPLOAD_FOLDER="beready/profile"
CLOUDINARY_DISABLE_SSL=true

# Google OAuth
GOOGLE_CLIENT_ID=seu_client_id_google.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=seu_client_secret_google
GOOGLE_REDIRECT_URI=seu_url_aqui

# FACEBOOK OAuth
FACEBOOK_CLIENT_ID=seu_facebook_app_id
FACEBOOK_CLIENT_SECRET=seu_facebook_app_secret
FACEBOOK_REDIRECT_URI=seu_url_aqui

# LINKEDIN OAuth
LINKEDIN_CLIENT_ID=seu_linkedin_client_id
LINKEDIN_CLIENT_SECRET=seu_linkedin_client_secret
LINKEDIN_REDIRECT_URI=seu_url_aqui

# URLs das APIs para Social Auth
GOOGLE_TOKEN_URL=seu_url_google_aqui
GOOGLE_USERINFO_URL=seu_url_google_aqui

FACEBOOK_TOKEN_URL=hseu_url_facebook_aqui
FACEBOOK_USERINFO_URL=seu_url_facebool_aqui

LINKEDIN_TOKEN_URL=seu_url_linkedin_aqui
LINKEDIN_USERINFO_URL=seu_url_linkedin_aqui

# Captcha 
RECAPTCHA_SECRET_KEY=sua_chave_captcha_aqui
RECAPTCHA_VERIFY_URL=https://www.google.com/recaptcha/api/siteverify